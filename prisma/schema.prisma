// Schema Prisma - ProspecLead SaaS Multi-Tenant
// SQLite compatible (roles e status como String)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  nome      String
  slug      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  leads     Lead[]
  products  Product[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nome      String
  /// ADMIN_MASTER | FINANCIAL | MANAGER
  role      String   @default("MANAGER")
  ativo     Boolean  @default(true)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leadsAuditados Lead[] @relation("AuditadoPor")
}

// ─────────────────────────────────────────────
// PRODUTO / CATÁLOGO
// ─────────────────────────────────────────────
model Product {
  id                   String   @id @default(cuid())
  name                 String
  /// HARDWARE | SUBSCRIPTION_PLAN
  type                 String   @default("HARDWARE")
  description          String?
  price                Float
  commissionPercentage Float    @default(30)
  isActive             Boolean  @default(true)
  tenantId             String?
  tenant               Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Lead {
  id              String   @id @default(cuid())
  /// Dados do cliente
  nomeCliente     String
  telefone        String?
  email           String?
  /// Dados do veículo
  veiculo         String   // ex: "Fiat Strada 2022"
  placa           String   // texto digitado pela promotora
  praca           String   // local/praça de captura
  /// Foto da placa (URL)
  platePhotoUrl   String?
  /// Status da auditoria
  /// PENDENTE_AUDITORIA | AUDITADO_APROVADO | AUDITADO_REJEITADO
  status          String   @default("PENDENTE_AUDITORIA")
  motivoRejeicao  String?
  /// Valores de comissão
  commissionValue Float    @default(1.00)
  /// Auditoria
  auditadoPorId   String?
  auditadoPor     User?    @relation("AuditadoPor", fields: [auditadoPorId], references: [id])
  auditadoEm      DateTime?
  /// Multi-tenant
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
