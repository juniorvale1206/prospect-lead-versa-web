// Schema Prisma - ProspecLead SaaS Multi-Tenant
// SQLite compatible (roles e status como String)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String    @id @default(cuid())
  nome         String
  slug         String    @unique

  /// CNPJ da franquia (formato: XX.XXX.XXX/XXXX-XX)
  document     String?

  /// URL da logo para personalização white-label
  logoUrl      String?

  /// Cor principal em HEX (ex: #10b981)
  primaryColor String?   @default("#10b981")

  /// STANDARD | PROFESSIONAL | ENTERPRISE
  plan         String?   @default("STANDARD")

  /// Dados de contato do responsável
  contactName  String?
  contactEmail String?
  contactPhone String?

  /// Localização
  city         String?
  state        String?

  /// Limites do plano
  maxUsers     Int       @default(10)
  maxLeads     Int       @default(1000)

  ativo        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users        User[]
  leads        Lead[]
  products     Product[]
  agents       Agent[]
  channels     Channel[]
  campaigns    Campaign[]
  tasks        Task[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nome      String
  /// ADMIN_MASTER | FINANCIAL | MANAGER | PROMOTER | PARTNER_EMPLOYEE
  role      String   @default("MANAGER")
  ativo     Boolean  @default(true)
  telefone  String?
  cpf       String?  @unique
  avatarUrl String?
  fotoUrl   String?

  /// PENDING | APPROVED | REJECTED  (controle de onboarding para promotores mobile)
  approvalStatus  String  @default("APPROVED")
  approvalNote    String?
  approvedById    String?
  approvedAt      DateTime?

  // ── KYC — documento de identidade ────────────────────────────────────────
  /// URL da foto do documento (CPF/RG) enviada pelo promotor
  cpfPhotoUrl     String?
  /// PENDING_REVIEW | VERIFIED | REJECTED  (status do KYC)
  kycStatus       String  @default("PENDING_REVIEW")
  kycReviewedAt   DateTime?
  kycNote         String?

  // ── Dados bancários / Pix ─────────────────────────────────────────────────
  /// CPF | EMAIL | TELEFONE | CNPJ | ALEATORIA
  pixKeyType      String?
  /// A chave Pix cadastrada pelo promotor
  pixKey          String?
  pixVerified     Boolean @default(false)

  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadsAuditados  Lead[]  @relation("AuditadoPor")
  leadsCapturados Lead[]  @relation("CapturadoPor")

  /// Vendas realizadas como promotor
  vendasRealizadas Sale[]  @relation("VendasPromotor")

  /// Comissões liquidadas (pagamentos realizados)
  commissionPayments CommissionPayment[]

  /// Tarefas atribuídas ao usuário
  tasks Task[]
}

// ─────────────────────────────────────────────
// TOKEN MOBILE — para invalidação futura
// ─────────────────────────────────────────────
model MobileToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceInfo  String?
  lastUsedAt  DateTime @default(now())
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// PRODUTO / CATÁLOGO
// ─────────────────────────────────────────────
model Product {
  id                   String   @id @default(cuid())
  name                 String
  /// HARDWARE | SUBSCRIPTION_PLAN
  type                 String   @default("HARDWARE")
  description          String?
  price                Float
  commissionPercentage Float    @default(30)
  isActive             Boolean  @default(true)

  // ── Adesão e Parcelamento (mobile sales flow) ──────────────────────────────
  /// Taxa de adesão (setup fee) cobrada na 1ª parcela. Default: 0
  setupFee             Float    @default(0)
  /// Permite parcelar no cartão de crédito?
  allowCreditCardInstallments Boolean @default(false)
  /// Número máximo de parcelas (1 = à vista)
  maxInstallments      Int      @default(1)
  /// Ciclos de cobrança suportados como JSON array.
  /// Ex: '["MONTHLY","ANNUALLY"]'
  /// Valores: MONTHLY | QUARTERLY | SEMI_ANNUALLY | ANNUALLY | ONE_TIME
  billingCycles        String   @default("[\"MONTHLY\"]")
  /// Valor base MENSAL da assinatura de plataforma vinculada ao hardware.
  /// Usado para calcular os totais trimestrais/semestrais/anuais no PDV.
  /// Aplica-se apenas a produtos do tipo HARDWARE. Default: 0
  monthlySubscriptionPrice Float @default(0)

  tenantId             String?
  tenant               Tenant?  @relation(fields: [tenantId], references: [id])

  /// Vendas deste produto
  sales                Sale[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────────
// LEAD — Funil de Vendas + Kanban
// ─────────────────────────────────────────────
model Lead {
  id              String    @id @default(cuid())

  // ── Dados do cliente ──────────────────────
  nomeCliente     String
  telefone        String?
  email           String?

  // ── Tipo do lead ──────────────────────────
  /// B2C | B2B
  leadType        String    @default("B2C")

  // ── B2C: dados veiculares ─────────────────
  veiculo         String    @default("")
  placa           String    @default("")
  praca           String    @default("")
  platePhotoUrl   String?

  // ── B2B: dados empresariais ───────────────
  cnpj            String?
  empresaNome     String?
  frota           String?
  segmento        String?

  // ── Qualificação / dores ──────────────────
  doresIdentificadas String?

  // ── Prospecção Ativa B2B (Radar) ──────────
  /// MANUAL | PROSPECCAO_ATIVA | INDICACAO | CAMPANHA_WPP | API
  sourceType      String    @default("MANUAL")
  /// CNAE principal da empresa (ex: "4930-2/02")
  cnae            String?
  /// CNAE descrição (ex: "Transporte rodoviário de carga")
  cnaeDescricao   String?
  /// Razão social completa (da Receita Federal)
  razaoSocial     String?
  /// Número de funcionários (porte da empresa)
  porte           String?
  /// Logradouro (rua/av)
  logradouro      String?
  /// Número do endereço
  numero          String?
  /// Complemento
  complemento     String?
  /// Bairro
  bairro          String?
  /// Município
  municipio       String?
  /// UF
  uf              String?
  /// CEP
  cep             String?
  /// Sócios / QSA serializado em JSON
  qsa             String?
  /// Google Place ID (para enriquecimento via Google Places)
  googlePlaceId   String?
  /// Situação cadastral Receita (ATIVA | BAIXADA | SUSPENSA)
  situacaoCadastral String?

  // ── Estágio do Funil (Kanban) ─────────────
  /// LEAD_COLETADO | IA_EM_ATENDIMENTO | REUNIAO_AGENDADA | CONVERTIDO
  funnelStage     String    @default("LEAD_COLETADO")

  // ── Interação com IA (SDR / PayMeZap) ────────────────────────────────────
  /// CONTATADO | RESPONDIDO  (atualizado pelo webhook da IA)
  iaStatus        String?
  /// Timestamp em que o cliente respondeu à IA pela 1ª vez
  iaRespondidoEm  DateTime?
  /// Telefone somente dígitos sem +55 (índice para busca rápida do webhook)
  telefoneNorm    String?

  // ── Auditoria de placa ────────────────────
  /// PENDENTE_AUDITORIA | AUDITADO_APROVADO | AUDITADO_REJEITADO
  status          String    @default("PENDENTE_AUDITORIA")
  motivoRejeicao  String?
  commissionValue Float     @default(1.00)
  auditadoPorId   String?
  auditadoPor     User?     @relation("AuditadoPor", fields: [auditadoPorId], references: [id])
  auditadoEm      DateTime?

  // ── Promotor / captura ────────────────────
  promotorId      String?
  promotor        User?     @relation("CapturadoPor", fields: [promotorId], references: [id])

  /// Vendas vinculadas a este lead
  sales           Sale[]

  /// Tarefas de follow-up vinculadas a este lead
  tasks           Task[]

  // ── Multi-tenant ──────────────────────────
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// VENDA — Fechamento de Negócio
// ─────────────────────────────────────────────
// Criada via POST /api/mobile/sales pelo app do promotor.
// A criação é atômica: Sale + Lead.status=VENDIDO + CommissionLedger.
model Sale {
  id            String   @id @default(cuid())

  // ── Relações ────────────────────────────────
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])

  promoterId    String
  promoter      User     @relation("VendasPromotor", fields: [promoterId], references: [id])

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  // ── Dados da transação ───────────────────────
  /// PIX | CREDIT_CARD | BOLETO | DINHEIRO
  paymentMethod String   @default("PIX")
  /// Número de parcelas (1 = à vista)
  installments  Int      @default(1)
  /// Valor total pago no ato (hardware + setup fee, etc.)
  totalAmount   Float

  // ── Assinatura vinculada ao hardware ────────
  /// Ciclo contratado: QUARTERLY | SEMI_ANNUALLY | ANNUALLY
  subscriptionCycle  String?
  /// Valor da assinatura para o ciclo contratado
  subscriptionAmount Float   @default(0)

  // ── Comissão gerada ──────────────────────────
  /// Valor de comissão calculado no ato da venda
  commissionAmount Float   @default(0)

  // ── Multi-tenant ────────────────────────────
  tenantId      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// EXTRATO ATÔMICO DE COMISSÃO (Ledger por Evento)
// ─────────────────────────────────────────────
// Cada linha = 1 crédito gerado por evento.
// Criado automaticamente pelo webhook IA ao confirmar resposta do lead.
model CommissionLedger {
  id          String   @id @default(cuid())
  /// Promotor que recebe o crédito
  promotorId  String
  /// Lead que gerou a comissão
  leadId      String
  /// IA_RESPONSE_WITH_PHOTO | IA_RESPONSE_NO_PHOTO | MANUAL_ADJUSTMENT | SALE_CONVERTED
  eventType   String
  /// Valor em R$ (positivo = crédito, negativo = estorno)
  amount      Float
  /// Texto legível no extrato do promotor
  description String
  /// PENDING (aguarda liquidação) | PAID (liquidado no fechamento mensal)
  status      String   @default("PENDING")
  tenantId    String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// OMNICHANNEL IA AGENTS
// ─────────────────────────────────────────────

/// Agente de IA configurado por tenant
model Agent {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  /// Modelo LLM: gpt-4o-mini | gpt-4o | claude-3-haiku | claude-3-sonnet
  model        String   @default("gpt-4o-mini")
  /// FORMAL | NORMAL | DESCONTRAIDA
  tone         String   @default("NORMAL")
  /// Prompt de sistema (instruções de comportamento)
  systemPrompt String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  knowledgeBases KnowledgeBase[]
  conversations  Conversation[]
}

/// Base de conhecimento do agente (RAG)
model KnowledgeBase {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// TEXT | WEBSITE | DOCUMENT
  type      String   @default("TEXT")
  /// Conteúdo bruto (texto, URL, ou caminho do arquivo)
  content   String
  /// Título/descrição amigável para exibição na UI
  title     String   @default("")
  /// TRAINED | PENDING | FAILED
  status    String   @default("PENDING")
  /// URL do embedding vetorial (Pinecone/pgvector namespace key)
  vectorKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Canal de comunicação (WhatsApp, Instagram, Webchat)
model Channel {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  /// WHATSAPP_META | INSTAGRAM | WEBCHAT
  type        String
  name        String   @default("")
  /// JSON serializado com credenciais (phone_number_id, access_token, etc.)
  credentials String   @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
}

/// Conversa/ticket entre um contato e um agente num canal
model Conversation {
  id         String   @id @default(cuid())
  /// Identificador externo do contato (número de telefone, user_id Instagram, etc.)
  contactId  String
  /// Nome do contato (preenchido via webhook ou pelo operador)
  contactName String  @default("")
  /// Foto/avatar do contato (URL)
  contactAvatar String? 

  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])

  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id])

  /// WAITING | BOT_HANDLING | HUMAN_HANDLING | RESOLVED
  status     String   @default("BOT_HANDLING")

  /// ID do operador humano que assumiu (opcional)
  assignedToId String?

  tenantId   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   Message[]
}

/// Mensagem individual de uma conversa
model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// USER | BOT | HUMAN
  senderType     String
  /// Nome do remetente (para exibição na timeline)
  senderName     String   @default("")
  content        String
  /// Tipo da mensagem: text | image | audio | document
  messageType    String   @default("text")
  /// URL de mídia (quando messageType != text)
  mediaUrl       String?
  /// Lida pelo operador?
  read           Boolean  @default(false)
  timestamp      DateTime @default(now())
}

// ─────────────────────────────────────────────
// PAGAMENTO DE COMISSÃO (Fechamento Financeiro)
// ─────────────────────────────────────────────
model CommissionPayment {
  id            String   @id @default(cuid())
  /// PROMOTER | PDV_OWNER | PARTNER_EMPLOYEE
  recipientType String
  recipientId   String
  recipient     User     @relation(fields: [recipientId], references: [id])

  /// PENDING | PAID
  status        String   @default("PENDING")
  totalLeads    Int      @default(0)
  totalSales    Float    @default(0)
  commissionAmount Float @default(0)

  /// Detalhamento JSON: [{tipo, qtd, valor}]
  breakdown     String?

  paidById      String?
  paidAt        DateTime?
  notes         String?

  periodStart   DateTime?
  periodEnd     DateTime?

  tenantId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// CAMPANHAS DE DISPARO EM MASSA (WhatsApp)
// ─────────────────────────────────────────────

/// Campanha de mensagens em massa via WhatsApp Cloud API
model Campaign {
  id              String   @id @default(cuid())

  /// Nome interno da campanha (ex: "Reativação Junho 2025")
  name            String
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  /// Nome do template aprovado na Meta (ex: "promocao_rastreador_anual")
  templateName    String
  /// Variáveis do template serializadas em JSON (ex: '{"1":"nome","2":"produto"}')
  templateVars    String   @default("{}")
  /// Idioma do template (ex: "pt_BR")
  templateLanguage String  @default("pt_BR")

  /// DRAFT | SCHEDULED | RUNNING | PAUSED | COMPLETED | FAILED
  status          String   @default("DRAFT")

  /// JSON serializado com os filtros de segmentação usados
  audienceFilters String   @default("{}")
  /// Total de leads alvo calculado no momento da criação
  audienceCount   Int      @default(0)

  /// Quando disparar (null = imediato)
  scheduledAt     DateTime?
  /// Quando realmente iniciou
  startedAt       DateTime?
  /// Quando finalizou
  completedAt     DateTime?

  /// Criado por qual usuário
  createdById     String?

  /// Métricas agregadas (atualizadas pelo webhook de status da Meta)
  totalSent       Int      @default(0)
  totalDelivered  Int      @default(0)
  totalRead       Int      @default(0)
  totalReplied    Int      @default(0)
  totalFailed     Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        CampaignMessage[]
}

/// Registro individual de cada mensagem enviada numa campanha
model CampaignMessage {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  /// ID do lead que recebeu a mensagem
  leadId       String?
  /// Número de telefone destinatário (E.164 sem +)
  phoneNumber  String
  /// Primeiro nome para variáveis do template
  contactName  String   @default("")

  /// ID da mensagem devolvido pela API da Meta (wamid)
  waMessageId  String?  @unique

  /// sent | delivered | read | failed | replied
  deliveryStatus String @default("sent")

  /// Timestamp do último status recebido via webhook
  statusUpdatedAt DateTime?

  /// Motivo de falha (se deliveryStatus = 'failed')
  errorMessage String?

  tenantId     String?
  createdAt    DateTime @default(now())
}

// Relação inversa no Tenant

// ─────────────────────────────────────────────
// TAREFAS DE FOLLOW-UP (CRM Tasks)
// ─────────────────────────────────────────────

/// Tarefa de follow-up vinculada a um Lead e a um Vendedor
model Task {
  id          String   @id @default(cuid())

  /// Título da tarefa (ex: "Ligar para Transportadora ABC")
  title       String

  /// Descrição opcional com contexto
  description String?

  /// Quando a tarefa deve ser executada
  dueDate     DateTime

  /// PENDING | IN_PROGRESS | COMPLETED | CANCELED
  status      String   @default("PENDING")

  /// CALL | EMAIL | WHATSAPP | MEETING | OTHER
  type        String   @default("CALL")

  /// Prioridade: LOW | MEDIUM | HIGH
  priority    String   @default("MEDIUM")

  /// Lead associado à tarefa
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// Vendedor responsável pela execução
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  /// Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  /// Quando foi concluída
  completedAt DateTime?

  /// Notas adicionadas ao concluir
  completionNotes String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
