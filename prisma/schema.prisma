// Schema Prisma - ProspecLead SaaS Multi-Tenant
// SQLite compatible (roles e status como String)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String    @id @default(cuid())
  nome         String
  slug         String    @unique

  /// CNPJ da franquia (formato: XX.XXX.XXX/XXXX-XX)
  document     String?

  /// URL da logo para personalização white-label
  logoUrl      String?

  /// Cor principal em HEX (ex: #10b981)
  primaryColor String?   @default("#10b981")

  /// STANDARD | PROFESSIONAL | ENTERPRISE
  plan         String?   @default("STANDARD")

  /// Dados de contato do responsável
  contactName  String?
  contactEmail String?
  contactPhone String?

  /// Localização
  city         String?
  state        String?

  /// Limites do plano
  maxUsers     Int       @default(10)
  maxLeads     Int       @default(1000)

  ativo        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users        User[]
  leads        Lead[]
  products     Product[]
  agents       Agent[]
  channels     Channel[]
  campaigns    Campaign[]
  tasks        Task[]
  integrations TenantIntegration[]

  /// PDVs (Postos/Lojas parceiras) vinculados ao tenant
  partnerStores PartnerStore[]

  /// Taxa de comissão de rede (%) paga ao Promotor-Gerente do PDV
  /// Padrão: 10.0 (R$ 10,00 em uma venda de R$ 100,00)
  networkCommissionPct Float @default(10.0)

  /// Modelos de comissionamento configurados pela franquia
  commissionModels CommissionModel[]
}

/// Integrações por Tenant — chaves de API de serviços externos
/// provider: WHATSAPP_META | ASAAS | SMART_GPS | (extensível)
model TenantIntegration {
  id          String   @id @default(cuid())

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// WHATSAPP_META | ASAAS | SMART_GPS
  provider    String

  /// Rótulo amigável (ex: "WhatsApp Rastremix")
  label       String?

  /// Chave principal (Access Token, API Key)
  apiKey      String?

  /// Segredo adicional (apiSecret, webhookSecret)
  apiSecret   String?

  /// Campo auxiliar (Phone Number ID para Meta, WABA ID etc.)
  apiKeyAux   String?

  /// URL do webhook gerado pelo sistema (read-only para o tenant)
  webhookUrl  String?

  /// PRODUCTION | SANDBOX
  environment String   @default("PRODUCTION")

  /// JSON extra (baseUrl, timeout, etc.)
  metadata    String?  @default("{}")

  isActive    Boolean  @default(true)

  /// Resultado do último teste de conexão
  lastTestedAt DateTime?
  lastTestOk   Boolean  @default(false)
  lastTestMsg  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, provider])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nome      String
  /// ADMIN_MASTER | FINANCIAL | MANAGER | PROMOTER | PARTNER_EMPLOYEE
  role      String   @default("MANAGER")
  ativo     Boolean  @default(true)
  telefone  String?
  cpf       String?  @unique
  avatarUrl String?
  fotoUrl   String?

  /// PENDING | APPROVED | REJECTED  (controle de onboarding para promotores mobile)
  approvalStatus  String  @default("APPROVED")
  approvalNote    String?
  approvedById    String?
  approvedAt      DateTime?

  // ── KYC — documento de identidade ────────────────────────────────────────
  /// URL da foto do documento (CPF/RG) enviada pelo promotor
  cpfPhotoUrl     String?
  /// PENDING_REVIEW | VERIFIED | REJECTED  (status do KYC)
  kycStatus       String  @default("PENDING_REVIEW")
  kycReviewedAt   DateTime?
  kycNote         String?

  // ── Dados bancários / Pix ─────────────────────────────────────────────────
  /// CPF | EMAIL | TELEFONE | CNPJ | ALEATORIA
  pixKeyType      String?
  /// A chave Pix cadastrada pelo promotor
  pixKey          String?
  pixVerified     Boolean @default(false)

  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadsAuditados  Lead[]  @relation("AuditadoPor")
  leadsCapturados Lead[]  @relation("CapturadoPor")

  /// Vendas realizadas como promotor
  vendasRealizadas Sale[]  @relation("VendasPromotor")

  /// Comissões liquidadas (pagamentos realizados)
  commissionPayments CommissionPayment[]

  /// Tarefas atribuídas ao usuário
  tasks Task[]

  /// Turnos de trabalho (promotor de rua)
  shifts PromoterShift[]

  /// PDVs que este promotor gerencia (relação de rede)
  managedStores PartnerStore[] @relation("ManagerPromoter")

  /// Vínculo como funcionário em PDVs (frentista, caixa, gerente local)
  pdvEmployeeRecords PdvEmployee[]

  /// Modelo de comissão atribuído a este usuário (quando é PARTNER_EMPLOYEE)
  commissionModelId  String?
  commissionModel    CommissionModel? @relation(fields: [commissionModelId], references: [id])

  /// Carteira financeira (Promotor / Frentista)
  wallet             Wallet?

  /// Visitas a PDVs agendadas para este promotor
  pdvVisits          PdvVisit[] @relation("PromotorVisits")
}

// ─────────────────────────────────────────────
// TOKEN MOBILE — para invalidação futura
// ─────────────────────────────────────────────
model MobileToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceInfo  String?
  lastUsedAt  DateTime @default(now())
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// PRODUTO / CATÁLOGO
// ─────────────────────────────────────────────
model Product {
  id                   String   @id @default(cuid())
  name                 String
  /// HARDWARE | SUBSCRIPTION_PLAN
  type                 String   @default("HARDWARE")
  description          String?
  price                Float
  commissionPercentage Float    @default(30)
  isActive             Boolean  @default(true)

  // ── Adesão e Parcelamento (mobile sales flow) ──────────────────────────────
  /// Taxa de adesão (setup fee) cobrada na 1ª parcela. Default: 0
  setupFee             Float    @default(0)
  /// Permite parcelar no cartão de crédito?
  allowCreditCardInstallments Boolean @default(false)
  /// Número máximo de parcelas (1 = à vista)
  maxInstallments      Int      @default(1)
  /// Ciclos de cobrança suportados como JSON array.
  /// Ex: '["MONTHLY","ANNUALLY"]'
  /// Valores: MONTHLY | QUARTERLY | SEMI_ANNUALLY | ANNUALLY | ONE_TIME
  billingCycles        String   @default("[\"MONTHLY\"]")
  /// Valor base MENSAL da assinatura de plataforma vinculada ao hardware.
  /// Usado para calcular os totais trimestrais/semestrais/anuais no PDV.
  /// Aplica-se apenas a produtos do tipo HARDWARE. Default: 0
  monthlySubscriptionPrice Float @default(0)

  tenantId             String?
  tenant               Tenant?  @relation(fields: [tenantId], references: [id])

  /// Vendas deste produto
  sales                Sale[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────────
// LEAD — Funil de Vendas + Kanban
// ─────────────────────────────────────────────
model Lead {
  id              String    @id @default(cuid())

  // ── Dados do cliente ──────────────────────
  nomeCliente     String
  telefone        String?
  email           String?

  // ── Tipo do lead ──────────────────────────
  /// B2C | B2B
  leadType        String    @default("B2C")

  // ── B2C: dados veiculares ─────────────────
  veiculo         String    @default("")
  placa           String    @default("")
  praca           String    @default("")
  platePhotoUrl   String?

  // ── B2B: dados empresariais ───────────────
  cnpj            String?
  empresaNome     String?
  frota           String?
  segmento        String?

  // ── Qualificação / dores ──────────────────
  doresIdentificadas String?

  // ── PDV de origem (Modo Frentista) ────────
  /// PDV que gerou o lead (null = lead direto do promotor)
  pdvId           String?
  pdv             PartnerStore? @relation(fields: [pdvId], references: [id])

  // ── Prospecção Ativa B2B (Radar) ──────────
  /// MANUAL | PROSPECCAO_ATIVA | INDICACAO | CAMPANHA_WPP | API | PDV
  sourceType      String    @default("MANUAL")
  /// CNAE principal da empresa (ex: "4930-2/02")
  cnae            String?
  /// CNAE descrição (ex: "Transporte rodoviário de carga")
  cnaeDescricao   String?
  /// Razão social completa (da Receita Federal)
  razaoSocial     String?
  /// Número de funcionários (porte da empresa)
  porte           String?
  /// Logradouro (rua/av)
  logradouro      String?
  /// Número do endereço
  numero          String?
  /// Complemento
  complemento     String?
  /// Bairro
  bairro          String?
  /// Município
  municipio       String?
  /// UF
  uf              String?
  /// CEP
  cep             String?
  /// Sócios / QSA serializado em JSON
  qsa             String?
  /// Google Place ID (para enriquecimento via Google Places)
  googlePlaceId   String?
  /// Situação cadastral Receita (ATIVA | BAIXADA | SUSPENSA)
  situacaoCadastral String?

  // ── Estágio do Funil (Kanban) ─────────────
  /// LEAD_COLETADO | IA_EM_ATENDIMENTO | REUNIAO_AGENDADA | CONVERTIDO
  funnelStage     String    @default("LEAD_COLETADO")

  // ── Interação com IA (SDR / PayMeZap) ────────────────────────────────────
  /// CONTATADO | RESPONDIDO  (atualizado pelo webhook da IA)
  iaStatus        String?
  /// Timestamp em que o cliente respondeu à IA pela 1ª vez
  iaRespondidoEm  DateTime?
  /// Telefone somente dígitos sem +55 (índice para busca rápida do webhook)
  telefoneNorm    String?

  // ── Auditoria de placa ────────────────────
  /// PENDENTE_AUDITORIA | AUDITADO_APROVADO | AUDITADO_REJEITADO
  status          String    @default("PENDENTE_AUDITORIA")
  motivoRejeicao  String?
  commissionValue Float     @default(1.00)
  auditadoPorId   String?
  auditadoPor     User?     @relation("AuditadoPor", fields: [auditadoPorId], references: [id])
  auditadoEm      DateTime?

  // ── Safra / Lote de Campanha ──────────────
  /// Safra automática calculada na entrada: "MM/YYYY"  ex: "03/2026"
  /// Agrupa leads por mês de captura para evitar fadiga em campanhas repetidas
  cohort          String?
  /// ID da última campanha enviada para este lead (evita spam)
  lastCampaignId  String?
  /// Timestamp do último disparo em massa recebido por este lead
  lastContactedAt DateTime?

  // ── Promotor / captura ────────────────────
  promotorId      String?
  promotor        User?     @relation("CapturadoPor", fields: [promotorId], references: [id])

  /// Vendas vinculadas a este lead
  sales           Sale[]

  /// Tarefas de follow-up vinculadas a este lead
  tasks           Task[]

  /// Ligações de IA realizadas para este lead
  callLogs        CallLog[]

  // ── Multi-tenant ──────────────────────────
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// VENDA — Fechamento de Negócio
// ─────────────────────────────────────────────
// Criada via POST /api/mobile/sales pelo app do promotor.
// A criação é atômica: Sale + Lead.status=VENDIDO + CommissionLedger.
model Sale {
  id            String   @id @default(cuid())

  // ── Relações ────────────────────────────────
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])

  promoterId    String
  promoter      User     @relation("VendasPromotor", fields: [promoterId], references: [id])

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  // ── Dados da transação ───────────────────────
  /// PIX | CREDIT_CARD | BOLETO | DINHEIRO
  paymentMethod String   @default("PIX")
  /// Número de parcelas (1 = à vista)
  installments  Int      @default(1)
  /// Valor total pago no ato (hardware + setup fee, etc.)
  totalAmount   Float

  // ── Assinatura vinculada ao hardware ────────
  /// Ciclo contratado: QUARTERLY | SEMI_ANNUALLY | ANNUALLY
  subscriptionCycle  String?
  /// Valor da assinatura para o ciclo contratado
  subscriptionAmount Float   @default(0)

  // ── Comissão gerada ──────────────────────────
  /// Valor de comissão calculado no ato da venda
  commissionAmount Float   @default(0)

  // ── Multi-tenant ────────────────────────────
  tenantId      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// EXTRATO ATÔMICO DE COMISSÃO (Ledger por Evento)
// ─────────────────────────────────────────────
// Cada linha = 1 crédito gerado por evento.
// Criado automaticamente pelo webhook IA ao confirmar resposta do lead.
model CommissionLedger {
  id          String   @id @default(cuid())

  /// Promotor que recebe o crédito
  promotorId  String

  /// Lead que gerou a comissão
  leadId      String

  /// Venda vinculada (opcional — preenchida na SALE_CONVERTED)
  saleId      String?

  // ── Tipo de Comissão ──────────────────────────────────────────────────────
  /// DIRECT_SALE       → comissão padrão do frentista/promotor pela venda
  /// PDV_NETWORK_SALE  → comissão de rede/gestão do Promotor-Gerente do PDV
  /// IA_RESPONSE_WITH_PHOTO | IA_RESPONSE_NO_PHOTO | MANUAL_ADJUSTMENT
  commissionType String @default("DIRECT_SALE")

  /// PDV que originou a comissão de rede (null para comissões diretas)
  pdvId       String?
  pdv         PartnerStore? @relation(fields: [pdvId], references: [id])

  /// IA_RESPONSE_WITH_PHOTO | IA_RESPONSE_NO_PHOTO | MANUAL_ADJUSTMENT | SALE_CONVERTED
  eventType   String

  /// Valor em R$ (positivo = crédito, negativo = estorno)
  amount      Float

  /// Texto legível no extrato do promotor
  description String

  /// PENDING (aguarda liquidação) | PAID (liquidado no fechamento mensal)
  status      String   @default("PENDING")

  tenantId    String?
  createdAt   DateTime @default(now())

  @@index([promotorId, status])
  @@index([saleId])
  @@index([pdvId])
  @@index([commissionType, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTNER STORE — PDV (Posto de Gasolina / Loja Parceira) no Modo Frentista
// ─────────────────────────────────────────────────────────────────────────────
//
// MODELO DE COMISSÃO DE REDE:
//   Um Promotor (SDR de rua) pode cadastrar e gerenciar N PDVs.
//   Quando um lead originado de um PDV converte em venda:
//     • Comissão DIRETA  → vai para o frentista que fechou a venda
//     • Comissão de REDE → vai para o Promotor-Gerente do PDV
//
// FLUXO:
//   Lead.pdvId → PartnerStore.managerPromoterId → CommissionLedger (PDV_NETWORK_SALE)
//
model PartnerStore {
  id          String   @id @default(cuid())

  // ── Identificação ─────────────────────────────────────────────────────────
  /// Nome comercial do PDV (ex: "Posto Ipiranga Centro", "Loja X")
  name        String

  /// CNPJ do estabelecimento (opcional)
  cnpj        String?

  /// Endereço completo
  address     String?
  cidade      String?
  uf          String?

  // ── Contato do responsável local ──────────────────────────────────────────
  ownerName   String?
  ownerPhone  String?

  // ── Tipo ──────────────────────────────────────────────────────────────────
  /// POSTO_COMBUSTIVEL | LOJA_VAREJO | OFICINA | TRANSPORTADORA | OUTROS
  storeType   String   @default("POSTO_COMBUSTIVEL")

  // ── Status ────────────────────────────────────────────────────────────────
  /// ACTIVE | INACTIVE | SUSPENDED
  status      String   @default("ACTIVE")

  // ── RELAÇÃO DE REDE: Promotor-Gerente ─────────────────────────────────────
  /// Promotor responsável pelo cadastro e gestão deste PDV.
  /// Recebe a "Comissão de Rede" em toda venda originada aqui.
  managerPromoterId String?
  managerPromoter   User?   @relation("ManagerPromoter", fields: [managerPromoterId], references: [id])

  // ── Taxa de comissão de rede específica deste PDV ─────────────────────────
  /// Se null, usa o valor padrão do Tenant (networkCommissionPct)
  /// Se definido, sobrescreve o padrão do tenant para este PDV
  customNetworkCommissionPct Float?

  // ── Multi-tenant ──────────────────────────────────────────────────────────
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  // ── Relações ──────────────────────────────────────────────────────────────
  /// Leads captados neste PDV
  leads       Lead[]

  /// Entradas do extrato de comissão de rede geradas por este PDV
  commissionLedgerEntries CommissionLedger[]

  /// Funcionários vinculados a este PDV
  employees PdvEmployee[]

  // ── Métricas ──────────────────────────────────────────────────────────────
  /// Total de leads captados (denormalized counter, atualizado via trigger)
  totalLeads  Int      @default(0)
  /// Total de vendas convertidas (denormalized counter)
  totalSales  Int      @default(0)

  /// Visitas agendadas / realizadas neste PDV
  pdvVisits   PdvVisit[] @relation("PdvVisits")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@index([managerPromoterId])
  @@index([cnpj])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMISSION MODEL — Tabela de Comissionamento Pré-Definida
// ─────────────────────────────────────────────────────────────────────────────
//
// CONCEITO:
//   Cada tenant (franquia) define seus próprios planos de remuneração.
//   Um CommissionModel é atribuído a um PdvEmployee no momento do cadastro,
//   definindo de forma imutável como aquele colaborador será pago.
//
// EXEMPLOS:
//   name: "Padrão Frentista"     → fixedValue: 50.00, percentageValue: null
//   name: "Alta Performance"     → fixedValue: 30.00, percentageValue: 5.0
//   name: "Comissão Pura"        → fixedValue: 0.00,  percentageValue: 8.0
//   name: "Gerente de Loja"      → fixedValue: 100.00, percentageValue: 3.0
//
// CÁLCULO APLICADO NA VENDA:
//   comissão = fixedValue + (totalAmount × percentageValue / 100)
//
model CommissionModel {
  id          String  @id @default(cuid())

  /// Nome descritivo do modelo (ex: "Padrão Frentista", "Alta Performance")
  name        String

  /// Valor fixo em R$ pago por venda convertida (pode ser zero)
  fixedValue  Float   @default(0.0)

  /// Percentual sobre o totalAmount da venda (opcional — null = sem percentual)
  percentageValue Float?

  /// Descrição opcional para exibição na UI do gestor
  description String?

  /// ACTIVE | INACTIVE
  status      String  @default("ACTIVE")

  // ── Multi-tenant ──────────────────────────────────────────────────────────
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])

  // ── Relações ──────────────────────────────────────────────────────────────
  /// Funcionários vinculados a este modelo
  employees   PdvEmployee[]

  /// Usuários com este modelo como padrão (User.commissionModelId)
  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PDV EMPLOYEE — Funcionário/Frentista Vinculado a um PDV
// ─────────────────────────────────────────────────────────────────────────────
//
// MODELO DE VÍNCULO:
//   Um mesmo User (com role PARTNER_EMPLOYEE) pode trabalhar em N PDVs
//   com funções e modelos de comissão diferentes em cada um.
//   O PdvEmployee é o pivot dessa relação N:N.
//
// FLUXO DE CADASTRO:
//   POST /api/mobile/pdv/employee → cria User (PARTNER_EMPLOYEE) + PdvEmployee
//   → vincula ao CommissionModel escolhido
//   → approvalStatus: PENDING (gestor precisa aprovar)
//
model PdvEmployee {
  id        String  @id @default(cuid())

  // ── Relação com o usuário do sistema ──────────────────────────────────────
  /// Usuário com role PARTNER_EMPLOYEE associado a este vínculo
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Relação com o PDV ─────────────────────────────────────────────────────
  /// PDV onde este funcionário atua
  pdvId     String
  pdv       PartnerStore @relation(fields: [pdvId], references: [id], onDelete: Cascade)

  // ── Modelo de comissão PRÉ-DEFINIDO no cadastro ───────────────────────────
  /// Obrigatório — define exatamente como este colaborador será remunerado
  commissionModelId String
  commissionModel   CommissionModel @relation(fields: [commissionModelId], references: [id])

  // ── Função no PDV ─────────────────────────────────────────────────────────
  /// FRENTISTA | CAIXA | GERENTE_LOCAL | PROMOTOR_EXTERNO | SUPERVISOR
  role      String  @default("FRENTISTA")

  // ── Status do vínculo ─────────────────────────────────────────────────────
  /// ACTIVE | INACTIVE | SUSPENDED
  status    String  @default("ACTIVE")

  /// Data de início no PDV
  startedAt DateTime @default(now())

  /// Data de saída (null = ainda ativo)
  endedAt   DateTime?

  /// Observações do gestor sobre este vínculo
  notes     String?

  // ── Multi-tenant ──────────────────────────────────────────────────────────
  tenantId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Um usuário só pode ter um vínculo ativo por PDV
  @@unique([userId, pdvId])
  @@index([pdvId, status])
  @@index([userId])
  @@index([commissionModelId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// OMNICHANNEL IA AGENTS
// ─────────────────────────────────────────────

/// Agente de IA configurado por tenant
model Agent {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  /// Modelo LLM: gpt-4o-mini | gpt-4o | claude-3-haiku | claude-3-sonnet
  model        String   @default("gpt-4o-mini")
  /// FORMAL | NORMAL | DESCONTRAIDA
  tone         String   @default("NORMAL")
  /// Prompt de sistema (instruções de comportamento)
  systemPrompt String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  knowledgeBases KnowledgeBase[]
  conversations  Conversation[]

  /// Ligações de IA realizadas por este agente
  callLogs       CallLog[]
}

/// Base de conhecimento do agente (RAG)
model KnowledgeBase {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// TEXT | WEBSITE | DOCUMENT
  type      String   @default("TEXT")
  /// Conteúdo bruto (texto, URL, ou caminho do arquivo)
  content   String
  /// Título/descrição amigável para exibição na UI
  title     String   @default("")
  /// TRAINED | PENDING | FAILED
  status    String   @default("PENDING")
  /// URL do embedding vetorial (Pinecone/pgvector namespace key)
  vectorKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Canal de comunicação (WhatsApp, Instagram, Webchat)
model Channel {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  /// WHATSAPP_META | INSTAGRAM | WEBCHAT
  type        String
  name        String   @default("")
  /// JSON serializado com credenciais (phone_number_id, access_token, etc.)
  credentials String   @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
}

/// Conversa/ticket entre um contato e um agente num canal
model Conversation {
  id         String   @id @default(cuid())
  /// Identificador externo do contato (número de telefone, user_id Instagram, etc.)
  contactId  String
  /// Nome do contato (preenchido via webhook ou pelo operador)
  contactName String  @default("")
  /// Foto/avatar do contato (URL)
  contactAvatar String? 

  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])

  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id])

  /// WAITING | BOT_HANDLING | HUMAN_HANDLING | RESOLVED
  status     String   @default("BOT_HANDLING")

  /// ID do operador humano que assumiu (opcional)
  assignedToId String?

  tenantId   String?

  // ── Smart Inbox / IA Qualification ──────────────────────────────────────────
  /// Indica se o Bot IA está ativo nesta conversa (true = IA responde, false = humano assumiu)
  isAiActive          Boolean  @default(true)

  /// Lead solicitou atendimento humano ("falar com atendente", etc.)
  fallbackRequested   Boolean  @default(false)

  /// Temperatura do lead avaliada pela IA: COLD | WARM | HOT
  leadTemperature     String?  @default("COLD")

  /// Intenção de compra identificada pela IA (ex: "Quer agendar instalação")
  buyingIntent        String?

  /// Principal objeção identificada (ex: "Achou caro", "Precisa de aprovação")
  mainObjection       String?

  /// Score de engajamento 0-100 (calculado pela IA)
  engagementScore     Int?     @default(0)

  /// Número de trocas de mensagem desde a última qualificação IA
  messagesSinceLastQualification Int @default(0)

  /// Quando foi a última qualificação pela IA
  lastQualifiedAt     DateTime?

  /// Timestamp da última mensagem NOSSA (bot ou humano) — usado pelo cron de follow-up
  lastOurMessageAt    DateTime?

  /// Quantas vezes o follow-up automático foi enviado
  followupCount       Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   Message[]
}

/// Mensagem individual de uma conversa
model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// USER | BOT | HUMAN | SYSTEM
  senderType     String
  /// Nome do remetente (para exibição na timeline)
  senderName     String   @default("")
  content        String
  /// Tipo da mensagem: text | image | audio | document
  messageType    String   @default("text")
  /// URL de mídia (quando messageType != text)
  mediaUrl       String?
  /// Lida pelo operador?
  read           Boolean  @default(false)

  // ── Nota Interna (Smart Inbox) ────────────────────────────────────────────
  /// Nota interna da equipe — NÃO enviada ao cliente (fundo amarelo na UI)
  isInternalNote Boolean  @default(false)

  /// Reação/emoji ao hover (futuro)
  reaction       String?

  timestamp      DateTime @default(now())
}

// ─────────────────────────────────────────────
// PAGAMENTO DE COMISSÃO (Fechamento Financeiro)
// ─────────────────────────────────────────────
model CommissionPayment {
  id            String   @id @default(cuid())
  /// PROMOTER | PDV_OWNER | PARTNER_EMPLOYEE
  recipientType String
  recipientId   String
  recipient     User     @relation(fields: [recipientId], references: [id])

  /// PENDING | PAID
  status        String   @default("PENDING")
  totalLeads    Int      @default(0)
  totalSales    Float    @default(0)
  commissionAmount Float @default(0)

  /// Detalhamento JSON: [{tipo, qtd, valor}]
  breakdown     String?

  paidById      String?
  paidAt        DateTime?
  notes         String?

  periodStart   DateTime?
  periodEnd     DateTime?

  tenantId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────
// CAMPANHAS DE DISPARO EM MASSA (WhatsApp)
// ─────────────────────────────────────────────

/// Campanha de mensagens em massa via WhatsApp Cloud API
model Campaign {
  id              String   @id @default(cuid())

  /// Nome interno da campanha (ex: "Reativação Junho 2025")
  name            String
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  /// Nome do template aprovado na Meta (ex: "promocao_rastreador_anual")
  templateName    String
  /// Variáveis do template serializadas em JSON (ex: '{"1":"nome","2":"produto"}')
  templateVars    String   @default("{}")
  /// Idioma do template (ex: "pt_BR")
  templateLanguage String  @default("pt_BR")

  /// DRAFT | SCHEDULED | RUNNING | PAUSED | COMPLETED | FAILED
  status          String   @default("DRAFT")

  /// JSON serializado com os filtros de segmentação usados
  audienceFilters String   @default("{}")
  /// Total de leads alvo calculado no momento da criação
  audienceCount   Int      @default(0)

  /// Quando disparar (null = imediato)
  scheduledAt     DateTime?
  /// Quando realmente iniciou
  startedAt       DateTime?
  /// Quando finalizou
  completedAt     DateTime?

  /// Criado por qual usuário
  createdById     String?

  /// Métricas agregadas (atualizadas pelo webhook de status da Meta)
  totalSent       Int      @default(0)
  totalDelivered  Int      @default(0)
  totalRead       Int      @default(0)
  totalReplied    Int      @default(0)
  totalFailed     Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        CampaignMessage[]
}

/// Registro individual de cada mensagem enviada numa campanha
model CampaignMessage {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  /// ID do lead que recebeu a mensagem
  leadId       String?
  /// Número de telefone destinatário (E.164 sem +)
  phoneNumber  String
  /// Primeiro nome para variáveis do template
  contactName  String   @default("")

  /// ID da mensagem devolvido pela API da Meta (wamid)
  waMessageId  String?  @unique

  /// sent | delivered | read | failed | replied
  deliveryStatus String @default("sent")

  /// Timestamp do último status recebido via webhook
  statusUpdatedAt DateTime?

  /// Motivo de falha (se deliveryStatus = 'failed')
  errorMessage String?

  tenantId     String?
  createdAt    DateTime @default(now())
}

// Relação inversa no Tenant

// ─────────────────────────────────────────────
// TAREFAS DE FOLLOW-UP (CRM Tasks)
// ─────────────────────────────────────────────

/// Tarefa de follow-up vinculada a um Lead e a um Vendedor
model Task {
  id          String   @id @default(cuid())

  /// Título da tarefa (ex: "Ligar para Transportadora ABC")
  title       String

  /// Descrição opcional com contexto
  description String?

  /// Quando a tarefa deve ser executada
  dueDate     DateTime

  /// PENDING | IN_PROGRESS | COMPLETED | CANCELED
  status      String   @default("PENDING")

  /// CALL | EMAIL | WHATSAPP | MEETING | OTHER
  type        String   @default("CALL")

  /// Prioridade: LOW | MEDIUM | HIGH
  priority    String   @default("MEDIUM")

  /// Lead associado à tarefa
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// Vendedor responsável pela execução
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  /// Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  /// Quando foi concluída
  completedAt DateTime?

  /// Notas adicionadas ao concluir
  completionNotes String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────
// VOICE AI — Ligações Automáticas Outbound
// ─────────────────────────────────────────────────────────────────

/// Registro de uma ligação de IA realizada para um Lead
model CallLog {
  id              String   @id @default(cuid())

  // ── Relações ─────────────────────────────────────────────────
  /// Lead que recebeu a ligação
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// Agente de IA que realizou a ligação (prompt, voz, objetivos)
  agentId         String?
  agent           Agent?   @relation(fields: [agentId], references: [id])

  /// Usuário do CRM que disparou a chamada
  dispatchedById  String?

  /// Multi-tenant
  tenantId        String?

  // ── Identificação no Provedor ─────────────────────────────────
  /// ID único da chamada no provedor de Voice AI (Vapi / Bland AI)
  providerCallId  String?  @unique

  /// VAPI | BLAND | TWILIO | MOCK
  provider        String   @default("VAPI")

  // ── Status ────────────────────────────────────────────────────
  /// QUEUED | RINGING | IN_PROGRESS | COMPLETED | NO_ANSWER | BUSY | FAILED | CANCELED
  status          String   @default("QUEUED")

  /// Código de encerramento do provedor (ex: "customer-ended-call", "assistant-error")
  endedReason     String?

  // ── Conteúdo da Ligação ───────────────────────────────────────
  /// URL da gravação de áudio (MP3/WAV) — disponível após o encerramento
  recordingUrl    String?

  /// Transcrição completa da conversa em texto (blocos JSON ou texto plano)
  transcript      String?

  /// Resumo gerado pela IA pós-chamada (ex: "Cliente achou caro, aceitou demo terça 14h")
  summary         String?

  /// Análise de sentimento: POSITIVE | NEUTRAL | NEGATIVE
  sentiment       String?

  /// Temperatura do lead pós-ligação: COLD | WARM | HOT
  callTemperature String?

  // ── Métricas ──────────────────────────────────────────────────
  /// Duração total em segundos
  durationSeconds Int      @default(0)

  /// Custo da ligação em centavos (cobrado pelo provedor)
  costCents       Int      @default(0)

  // ── Resultado da Ligação ──────────────────────────────────────
  /// A IA conseguiu agendar uma reunião?
  meetingScheduled Boolean @default(false)

  /// Data/hora agendada (preenchida quando meetingScheduled=true)
  meetingScheduledAt DateTime?

  /// Notas da IA sobre o resultado (objeções, próximos passos)
  callNotes       String?

  // ── Tool Calls (funções acionadas pela IA durante a ligação) ──
  /// JSON array com as tool calls registradas: [{name, args, result, timestamp}]
  toolCalls       String?  @default("[]")

  // ── Timestamps ────────────────────────────────────────────────
  /// Quando a chamada foi iniciada pelo provedor
  startedAt       DateTime?

  /// Quando a chamada foi encerrada
  endedAt         DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([leadId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([providerCallId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROMOTER SHIFT — Controle de Turno do Promotor de Rua
// ─────────────────────────────────────────────────────────────────────────────
/// Registro de cada turno de trabalho de um promotor.
/// Um turno é criado quando o promotor faz check-in e encerrado no check-out.
model PromoterShift {
  id          String   @id @default(cuid())

  /// Promotor que está em turno
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Multi-tenant
  tenantId    String?

  // ── Status do Turno ─────────────────────────────────────────────────────
  /// ACTIVE | PAUSED_BY_INACTIVITY | PAUSED_BY_USER | ENDED
  status      String   @default("ACTIVE")

  // ── Timestamps do turno ─────────────────────────────────────────────────
  /// Início do turno (check-in)
  startedAt   DateTime @default(now())

  /// Fim do turno (check-out)
  endedAt     DateTime?

  /// Quando foi pausado por ociosidade (útil para cálculo)
  pausedAt    DateTime?

  /// Quantas vezes foi pausado por inatividade neste turno
  inactivityPauseCount Int @default(0)

  // ── Métricas do turno ───────────────────────────────────────────────────
  /// Leads cadastrados neste turno
  leadsCount  Int      @default(0)

  /// Localização do promotor ao fazer check-in (lat,lng ou endereço)
  checkInLocation  String?

  /// Localização ao fazer check-out
  checkOutLocation String?

  /// Observações do promotor ou do sistema
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([status, updatedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ALERT LOG — Alertas gerados pelo sistema (ociosidade, metas, etc.)
// ─────────────────────────────────────────────────────────────────────────────
model AlertLog {
  id          String   @id @default(cuid())

  /// Tenant ao qual pertence o alerta
  tenantId    String?

  /// Usuário que GEROU o alerta (ex: o promotor ocioso)
  subjectUserId   String?

  /// Tipo de alerta
  /// INACTIVITY | SHIFT_STARTED | SHIFT_ENDED | GOAL_REACHED | GOAL_MISSED
  type        String

  /// Título curto do alerta (para listagem)
  title       String

  /// Mensagem completa do alerta
  message     String

  /// Dados extras em JSON (ex: {"leadsCount": 3, "shiftId": "xxx"})
  metadata    String?  @default("{}")

  /// Alerta foi visualizado/resolvido pelo gestor?
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  resolvedById String?

  /// Severidade: INFO | WARNING | CRITICAL
  severity    String   @default("WARNING")

  createdAt   DateTime @default(now())

  @@index([tenantId, resolved, createdAt(sort: Desc)])
  @@index([subjectUserId, createdAt(sort: Desc)])
  @@index([type, resolved])
}

// ─────────────────────────────────────────────────────────────────────────────
// MOTOR FINANCEIRO — CARTEIRA (WALLET)
// ─────────────────────────────────────────────────────────────────────────────
//
// ARQUITETURA DE DUPLO-LIVRO:
//
//   CommissionLedger  ←→  Wallet
//   ─────────────────────────────
//   CommissionLedger é o livro contábil de COMISSÕES (eventos de negócio):
//     • PENDING  → comissão registrada, aguardando aprovação/liquidação
//     • PAID     → comissão aprovada e creditada na Wallet
//
//   Wallet é o saldo real disponível para saque:
//     • availableBalance → soma dos créditos já liquidados (PAID) menos saques
//     • pendingBalance   → soma das comissões ainda PENDING (leitura do ledger)
//     • lockedBalance    → valor em saques solicitados ainda não processados
//
//   Fluxo:
//     1. Venda fechada → CommissionLedger(PENDING) criado
//     2. Gestor aprova → CommissionLedger → PAID → Wallet.availableBalance += amount
//                        + WalletTransaction(CREDIT, source=COMMISSION_PAID)
//     3. Promotor solicita saque → WithdrawalRequest(PENDING)
//                        + Wallet.availableBalance -= amount
//                        + Wallet.lockedBalance   += amount
//                        + WalletTransaction(DEBIT, source=WITHDRAWAL_REQUEST)
//     4. Financeiro processa → WithdrawalRequest → APPROVED
//                        + Wallet.lockedBalance   -= amount
//                        + WalletTransaction(DEBIT, source=WITHDRAWAL_PAID)
//       (ou REJECTED)   + Wallet.lockedBalance   -= amount
//                        + Wallet.availableBalance += amount (estorno)
//                        + WalletTransaction(CREDIT, source=WITHDRAWAL_REVERSED)
//
// ANTI-RACE-CONDITION:
//   Todos os débitos e créditos usam prisma.$transaction([]) para garantir
//   atomicidade. O campo version (optimistic lock) previne double-spend.
//
// ─────────────────────────────────────────────────────────────────────────────

model Wallet {
  id     String @id @default(cuid())

  // ── Proprietário ─────────────────────────────────────────────────────────
  /// Um usuário tem exatamente uma Wallet (PROMOTER | PARTNER_EMPLOYEE)
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Saldos ───────────────────────────────────────────────────────────────
  /// Saldo disponível para saque (comissões liquidadas - saques)
  availableBalance Float @default(0.0)

  /// Saldo bloqueado em saques solicitados ainda não processados
  lockedBalance    Float @default(0.0)

  // ── Controle de concorrência (Optimistic Lock) ────────────────────────────
  /// Versão incrementada a cada atualização de saldo — evita race condition
  version          Int   @default(0)

  // ── Multi-tenant ─────────────────────────────────────────────────────────
  tenantId         String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relações
  transactions     WalletTransaction[]
  withdrawals      WithdrawalRequest[]

  @@index([userId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WALLET TRANSACTION — Extrato da Carteira
// ─────────────────────────────────────────────────────────────────────────────
//
//  Cada linha do extrato representa uma movimentação de saldo na Wallet.
//  type  = CREDIT → saldo aumentou   (comissão liquidada, estorno de saque)
//  type  = DEBIT  → saldo diminuiu   (saque solicitado)
//
//  source identifica a ORIGEM:
//    COMMISSION_PAID        → comissão do CommissionLedger foi aprovada
//    WITHDRAWAL_REQUEST     → débito ao solicitar saque (pending → lockedBalance)
//    WITHDRAWAL_PAID        → saque processado e pago (lockedBalance → 0)
//    WITHDRAWAL_REVERSED    → saque rejeitado, valor estornado para availableBalance
//    MANUAL_CREDIT          → crédito manual pelo financeiro/admin
//    MANUAL_DEBIT           → débito manual (ex: estorno de venda cancelada)
//
// ─────────────────────────────────────────────────────────────────────────────

model WalletTransaction {
  id       String @id @default(cuid())

  // ── Carteira proprietária ─────────────────────────────────────────────────
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // ── Tipo de movimentação ──────────────────────────────────────────────────
  /// CREDIT | DEBIT
  type     String

  /// Origem da transação
  /// COMMISSION_PAID | WITHDRAWAL_REQUEST | WITHDRAWAL_PAID |
  /// WITHDRAWAL_REVERSED | MANUAL_CREDIT | MANUAL_DEBIT
  source   String  @default("COMMISSION_PAID")

  // ── Valores ───────────────────────────────────────────────────────────────
  /// Valor absoluto em R$ (sempre positivo; o type indica crédito ou débito)
  amount   Float

  /// Saldo disponível APÓS esta transação (snapshot para o extrato)
  balanceAfter Float @default(0.0)

  // ── Rastreabilidade ───────────────────────────────────────────────────────
  /// Texto legível no extrato:
  ///   "Comissão: Venda Rastreador - Placa ABC1234"
  ///   "Saque PIX solicitado"
  ///   "Estorno de saque rejeitado"
  description  String

  /// Referência opcional ao CommissionLedger que gerou este crédito
  commissionLedgerId String?

  /// Referência opcional ao WithdrawalRequest vinculado
  withdrawalRequestId String?

  // ── Multi-tenant ─────────────────────────────────────────────────────────
  tenantId   String?

  createdAt  DateTime @default(now())

  @@index([walletId, createdAt(sort: Desc)])
  @@index([walletId, type])
  @@index([source])
  @@index([commissionLedgerId])
  @@index([withdrawalRequestId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WITHDRAWAL REQUEST — Pedido de Saque
// ─────────────────────────────────────────────────────────────────────────────
//
//  Ciclo de vida:
//    PENDING   → aguardando análise do financeiro
//    APPROVED  → pago via Pix pelo financeiro
//    REJECTED  → negado; valor retorna para availableBalance
//
//  Ao criar (PENDING):
//    • availableBalance -= amount
//    • lockedBalance    += amount
//    • WalletTransaction(DEBIT, WITHDRAWAL_REQUEST) criado
//
//  Ao aprovar (APPROVED):
//    • lockedBalance -= amount
//    • WalletTransaction(DEBIT, WITHDRAWAL_PAID) criado
//
//  Ao rejeitar (REJECTED):
//    • lockedBalance    -= amount
//    • availableBalance += amount  (estorno)
//    • WalletTransaction(CREDIT, WITHDRAWAL_REVERSED) criado
//
// ─────────────────────────────────────────────────────────────────────────────

model WithdrawalRequest {
  id       String @id @default(cuid())

  // ── Carteira proprietária ─────────────────────────────────────────────────
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // ── Dados do saque ────────────────────────────────────────────────────────
  amount   Float

  /// Chave Pix informada pelo solicitante
  pixKey   String

  /// Tipo da chave: CPF | EMAIL | TELEFONE | CNPJ | ALEATORIA
  pixKeyType String @default("CPF")

  // ── Status ────────────────────────────────────────────────────────────────
  /// PENDING | APPROVED | REJECTED | CANCELLED
  status   String  @default("PENDING")

  /// Nota do financeiro ao aprovar ou rejeitar
  reviewNote String?

  /// Quem aprovou/rejeitou (userId do operador financeiro)
  reviewedById String?

  // ── Timestamps ────────────────────────────────────────────────────────────
  requestedAt  DateTime  @default(now())
  processedAt  DateTime?

  // ── Multi-tenant ─────────────────────────────────────────────────────────
  tenantId     String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([walletId, status])
  @@index([status, requestedAt(sort: Desc)])
  @@index([tenantId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PDV VISIT — Agenda de Visitas do Promotor
// ─────────────────────────────────────────────────────────────────────────────
//
//  Ciclo de vida:
//    SCHEDULED   → visita agendada (criada pelo gestor ou promotor)
//    IN_PROGRESS → promotor fez check-in no PDV
//    COMPLETED   → promotor fez check-out; durationMinutes calculado
//    CANCELED    → visita cancelada antes de ocorrer
//
//  Fluxo:
//    1. Criar visita com status SCHEDULED + scheduledDate
//    2. POST /:id/checkin → status=IN_PROGRESS, checkInAt=now(), checkInLocation
//    3. POST /:id/checkout → status=COMPLETED, checkOutAt=now(),
//       durationMinutes = diff(checkOutAt, checkInAt)
//
// ─────────────────────────────────────────────────────────────────────────────

// NOTE: SQLite does not support enums.
// PdvVisit.status valid values: SCHEDULED | IN_PROGRESS | COMPLETED | CANCELED

model PdvVisit {
  id            String         @id @default(cuid())

  // ── Relações ───────────────────────────────────────────────────────────────
  promotorId    String
  promotor      User           @relation("PromotorVisits", fields: [promotorId], references: [id])

  pdvId         String
  pdv           PartnerStore   @relation("PdvVisits", fields: [pdvId], references: [id])

  // ── Agendamento ────────────────────────────────────────────────────────────
  scheduledDate DateTime

  // ── Status ─────────────────────────────────────────────────────────────────
  /// SCHEDULED | IN_PROGRESS | COMPLETED | CANCELED
  status        String         @default("SCHEDULED")

  // ── Check-in / Check-out ───────────────────────────────────────────────────
  /// Timestamp de quando o promotor chegou ao PDV
  checkInAt       DateTime?

  /// Coordenadas ou endereço capturado no check-in (ex: "-23.5505,-46.6333")
  checkInLocation String?

  /// Timestamp de quando o promotor encerrou a visita
  checkOutAt      DateTime?

  /// Duração total calculada em minutos (checkOutAt - checkInAt)
  durationMinutes Int?

  /// Anotações opcionais registradas no check-out
  visitNotes      String?

  // ── Multi-tenant ───────────────────────────────────────────────────────────
  tenantId      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([promotorId, scheduledDate])
  @@index([pdvId, scheduledDate])
  @@index([status, scheduledDate])
  @@index([tenantId, scheduledDate])
}
