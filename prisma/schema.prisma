// Schema Prisma - ProspecLead SaaS Multi-Tenant
// SQLite compatible (roles e status como String)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  nome      String
  slug      String    @unique
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  leads     Lead[]
  products  Product[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nome      String
  /// ADMIN_MASTER | FINANCIAL | MANAGER
  role      String   @default("MANAGER")
  ativo     Boolean  @default(true)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadsAuditados  Lead[]  @relation("AuditadoPor")
  leadsCapturados Lead[]  @relation("CapturadoPor")
}

// ─────────────────────────────────────────────
// PRODUTO / CATÁLOGO
// ─────────────────────────────────────────────
model Product {
  id                   String   @id @default(cuid())
  name                 String
  /// HARDWARE | SUBSCRIPTION_PLAN
  type                 String   @default("HARDWARE")
  description          String?
  price                Float
  commissionPercentage Float    @default(30)
  isActive             Boolean  @default(true)
  tenantId             String?
  tenant               Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────────
// LEAD — Funil de Vendas + Kanban
// ─────────────────────────────────────────────
model Lead {
  id              String    @id @default(cuid())

  // ── Dados do cliente ──────────────────────
  nomeCliente     String
  telefone        String?
  email           String?

  // ── Tipo do lead ──────────────────────────
  /// B2C | B2B
  leadType        String    @default("B2C")

  // ── B2C: dados veiculares ─────────────────
  veiculo         String    @default("")
  placa           String    @default("")
  praca           String    @default("")
  platePhotoUrl   String?

  // ── B2B: dados empresariais ───────────────
  cnpj            String?
  empresaNome     String?
  frota           String?        // ex: "50 caminhões", "12 vans"
  segmento        String?        // ex: "Transporte", "Mineração"

  // ── Qualificação / dores ──────────────────
  doresIdentificadas String?     // texto livre ou JSON stringify

  // ── Estágio do Funil (Kanban) ─────────────
  /// LEAD_COLETADO | IA_EM_ATENDIMENTO | REUNIAO_AGENDADA | CONVERTIDO
  funnelStage     String    @default("LEAD_COLETADO")

  // ── Auditoria de placa ────────────────────
  /// PENDENTE_AUDITORIA | AUDITADO_APROVADO | AUDITADO_REJEITADO
  status          String    @default("PENDENTE_AUDITORIA")
  motivoRejeicao  String?
  commissionValue Float     @default(1.00)
  auditadoPorId   String?
  auditadoPor     User?     @relation("AuditadoPor", fields: [auditadoPorId], references: [id])
  auditadoEm      DateTime?

  // ── Promotor / captura ────────────────────
  promotorId      String?
  promotor        User?     @relation("CapturadoPor", fields: [promotorId], references: [id])

  // ── Multi-tenant ──────────────────────────
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
